# Vercel runtime: Supabase transaction pooler (usually port 6543) with pgbouncer=true
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# Prisma CLI / db push / studio: direct DB URL or Supabase session pooler (usually port 5432)
DIRECT_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
# Optional catalog visibility mode: all | no_demo | verified_only
ODORA_CATALOG_MODE=verified_only
# Vercel/Supabase recommended starting point: keep this at 1, then test 2 only if needed.
ODORA_DB_CONNECTION_LIMIT=1
ODORA_DB_POOL_TIMEOUT=20
ODORA_PRELAUNCH_MODE=false
ODORA_SITE_PASSWORD=<LONG_RANDOM_PRELAUNCH_PASSWORD_REQUIRED_IF_ODORA_PRELAUNCH_MODE=true>
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=2erre-21
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<SUPABASE_PUBLISHABLE_KEY>
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ODORA_REVALIDATE_TOKEN=<LONG_RANDOM_SECRET>
ODORA_REVALIDATE_URL=http://localhost:3000/api/revalidate
ODORA_AUTH_EMAIL_PROVIDER=supabase
RESEND_API_KEY=<RESEND_API_KEY>
ODORA_EMAIL_FROM=Odora <hello@your-domain.com>
ODORA_EMAIL_REPLY_TO=hello@your-domain.com
ODORA_CRON_SECRET=<LONG_RANDOM_CRON_SECRET>
ODORA_NEWSLETTER_TOKEN_SECRET=<LONG_RANDOM_NEWSLETTER_TOKEN_SECRET>
ODORA_WEEKLY_EMAIL_LIMIT=200
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>
SUPABASE_STORAGE_BUCKET=perfumes
