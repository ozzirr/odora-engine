{
  "name": "odora",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema=prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "homepage:bootstrap": "tsx scripts/homepage/bootstrap-content.ts",
    "generate:parfumo-dataset": "tsx scripts/import/generate-parfumo-dataset.ts",
    "import:parfumo:dry": "tsx scripts/import/import-parfumo.ts --dry-run --limit=2000",
    "import:parfumo": "tsx scripts/import/import-parfumo.ts --limit=2000",
    "parfumo:tops:fetch": "tsx scripts/import/fetch-parfumo-tops.ts --pages=5",
    "parfumo:tops:fetch:dry": "tsx scripts/import/fetch-parfumo-tops.ts --dry-run --pages=1",
    "parfumo:tops:import:dry": "tsx scripts/import/import-parfumo-tops.ts --dry-run",
    "parfumo:tops:import": "tsx scripts/import/import-parfumo-tops.ts",
    "import:verified:dry": "tsx scripts/import/import-verified-catalog.ts --dry-run --input=data/verified/perfumes.csv",
    "import:verified": "tsx scripts/import/import-verified-catalog.ts --input=data/verified/perfumes.csv",
    "import:verified:notes:dry": "tsx scripts/import/import-verified-catalog.ts --notes-only --dry-run --input=data/verified/perfumes.csv",
    "import:verified:notes": "tsx scripts/import/import-verified-catalog.ts --notes-only --input=data/verified/perfumes.csv",
    "sync:verified:images": "tsx scripts/import/sync-verified-images.ts --input=data/verified/perfumes.csv",
    "sync:verified:images:force": "tsx scripts/import/sync-verified-images.ts --force --input=data/verified/perfumes.csv",
    "images:bulk-upload:dry": "tsx scripts/import/bulk-upload-approved-images.ts --dry-run",
    "images:bulk-upload": "tsx scripts/import/bulk-upload-approved-images.ts",
    "images:bulk-upload:db": "tsx scripts/import/bulk-upload-approved-images.ts --update-db",
    "images:bulk-upload:diagnostic": "tsx scripts/import/bulk-upload-approved-images.ts --diagnostic",
    "images:fetch": "tsx scripts/import/fetch-images-from-brave.ts",
    "images:fetch:dry": "tsx scripts/import/fetch-images-from-brave.ts --dry-run",
    "images:manifest:generate": "tsx scripts/import/generate-approved-images-manifest.ts",
    "images:manifest:from-db": "tsx scripts/import/generate-missing-images-manifest-from-db.ts --limit=2000 --status=all",
    "images:pipeline:overnight": "tsx scripts/import/run-overnight-image-pipeline.ts --limit=2000 --batch-size=100 --sleep-ms=1500 --status=all",
    "images:pipeline:overnight:dry": "tsx scripts/import/run-overnight-image-pipeline.ts --dry-run --limit=2000 --batch-size=100 --sleep-ms=0 --status=all",
    "images:repair-paths:dry": "tsx scripts/import/repair-image-storage-paths.ts --dry-run",
    "images:repair-paths": "tsx scripts/import/repair-image-storage-paths.ts",
    "images:suggest-sources": "tsx scripts/import/suggest-image-source-urls.ts --missing-images-only",
    "images:suggest-sources:verified": "tsx scripts/import/suggest-image-source-urls.ts --status=VERIFIED --missing-images-only",
    "images:worklist": "tsx scripts/import/fill-verified-image-fields.ts --missing-images-only",
    "images:worklist:verified": "tsx scripts/import/fill-verified-image-fields.ts --status=VERIFIED --missing-images-only",
    "catalog:backfill:provenance:dry": "tsx scripts/import/backfill-catalog-provenance.ts",
    "catalog:backfill:provenance": "tsx scripts/import/backfill-catalog-provenance.ts --apply"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
