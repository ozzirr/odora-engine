generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MEN
  WOMEN
  UNISEX
}

enum NoteType {
  TOP
  HEART
  BASE
}

enum PriceRange {
  BUDGET
  MID
  PREMIUM
  LUXURY
}

enum CatalogStatus {
  DEMO
  IMPORTED_UNVERIFIED
  VERIFIED
}

enum SourceType {
  INTERNAL_DEMO
  MANUAL_CURATION
  COMMERCIAL_LICENSED
  BRAND_OFFICIAL
  PARTNER_FEED
  OTHER
}

enum DataQuality {
  LOW
  MEDIUM
  HIGH
}

enum HomepageSection {
  HERO
  TRENDING
  FEATURED
  EDITORIAL_VANILLA
  EDITORIAL_ARABIC
  EDITORIAL_OFFICE_SAFE
  SEASONAL_SUMMER
  SEASONAL_WINTER
}

enum HomepageCollectionType {
  FINDER_PRESET
  CATALOG_ROUTE
}

enum PerfumeListVisibility {
  PRIVATE
  PUBLIC
}

enum NewsletterSubscriberStatus {
  SUBSCRIBED
  UNSUBSCRIBED
}

model User {
  id        String        @id
  email     String?
  name      String?
  bio       String?
  countryCode String?
  birthDate DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  lists     PerfumeList[]
  listSaves PerfumeListSave[]
  perfumeReviews PerfumeReview[]
  perfumePurchasePrices PerfumePurchasePrice[]
}

model Brand {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  country     String?
  description String?
  logoUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  perfumes    Perfume[]
}

model Perfume {
  id                 Int                        @id @default(autoincrement())
  brandId            Int
  name               String
  slug               String                     @unique
  gender             Gender
  descriptionShort   String
  descriptionLong    String
  fragranceFamily    String
  priceRange         PriceRange
  releaseYear        Int?
  isArabic           Boolean                    @default(false)
  isNiche            Boolean                    @default(false)
  imageUrl           String?
  ratingInternal     Float?
  longevityScore     Int?
  sillageScore       Int?
  versatilityScore   Int?
  catalogStatus      CatalogStatus              @default(DEMO)
  sourceName         String?
  sourceType         SourceType                 @default(INTERNAL_DEMO)
  officialSourceUrl  String?
  amazonUrl          String?
  sourceConfidence   Float?
  dataQuality        DataQuality                @default(LOW)
  bestPriceAmount    Float?
  bestTotalPriceAmount Float?
  bestCurrency       String?
  bestStoreName      String?
  bestOfferUrl       String?
  bestOfferUpdatedAt DateTime?
  hasAvailableOffer  Boolean                    @default(false)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  brand              Brand                      @relation(fields: [brandId], references: [id], onDelete: Restrict)
  notes              PerfumeNote[]
  moods              PerfumeMood[]
  seasons            PerfumeSeason[]
  occasions          PerfumeOccasion[]
  offers             Offer[]
  homepagePlacements PerfumeHomepagePlacement[]
  listItems          PerfumeListItem[]
  reviews            PerfumeReview[]
  purchasePrices     PerfumePurchasePrice[]

  @@index([brandId])
  @@index([fragranceFamily])
  @@index([gender])
  @@index([priceRange])
  @@index([catalogStatus])
  @@index([dataQuality])
  @@index([bestTotalPriceAmount])
  @@index([hasAvailableOffer, bestTotalPriceAmount])
  @@index([ratingInternal(sort: Desc), updatedAt(sort: Desc), name], map: "perfume_rating_updated_name_idx")
  @@index([isArabic, ratingInternal(sort: Desc), updatedAt(sort: Desc)], map: "perfume_arabic_rating_updated_idx")
  @@index([isNiche, ratingInternal(sort: Desc), updatedAt(sort: Desc)], map: "perfume_niche_rating_updated_idx")
  @@index([longevityScore(sort: Desc), ratingInternal(sort: Desc), updatedAt(sort: Desc)], map: "perfume_longevity_rating_updated_idx")
  @@index([hasAvailableOffer, bestTotalPriceAmount, ratingInternal(sort: Desc), name], map: "perfume_offer_price_rating_name_idx")
  @@index([gender, ratingInternal(sort: Desc), name], map: "perfume_gender_rating_name_idx")
  @@index([priceRange, ratingInternal(sort: Desc), name], map: "perfume_price_range_rating_name_idx")
  @@index([fragranceFamily, ratingInternal(sort: Desc), name], map: "perfume_family_rating_name_idx")
}

model PerfumeReview {
  id               Int      @id @default(autoincrement())
  userId           String
  perfumeId        Int
  source           String   @default("user")
  longevityScore   Int
  sillageScore     Int
  versatilityScore Int
  text             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  perfume          Perfume  @relation(fields: [perfumeId], references: [id], onDelete: Cascade)

  @@unique([userId, perfumeId])
  @@index([perfumeId])
  @@index([userId])
  @@index([source])
  @@index([createdAt])
}

model PerfumePurchasePrice {
  id           Int      @id @default(autoincrement())
  userId       String
  perfumeId    Int
  source       String   @default("user")
  priceAmount  Float
  currency     String   @default("EUR")
  countryCode  String?
  storeName    String?
  purchaseDate DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  perfume      Perfume  @relation(fields: [perfumeId], references: [id], onDelete: Cascade)

  @@index([perfumeId])
  @@index([userId])
  @@index([source])
  @@index([countryCode])
  @@index([createdAt])
}

model PerfumeList {
  id          Int                   @id @default(autoincrement())
  userId      String
  name        String
  slug        String
  description String?
  visibility  PerfumeListVisibility @default(PRIVATE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       PerfumeListItem[]
  saves       PerfumeListSave[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([visibility])
}

model PerfumeListSave {
  id        Int         @id @default(autoincrement())
  userId    String
  listId    Int
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  list      PerfumeList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([userId, listId])
  @@index([listId])
  @@index([userId])
}

model PerfumeListItem {
  id        Int         @id @default(autoincrement())
  listId    Int
  perfumeId Int
  note      String?
  position  Int?
  createdAt DateTime    @default(now())
  list      PerfumeList @relation(fields: [listId], references: [id], onDelete: Cascade)
  perfume   Perfume     @relation(fields: [perfumeId], references: [id], onDelete: Cascade)

  @@unique([listId, perfumeId])
  @@index([perfumeId])
  @@index([listId, position])
}

model Note {
  id       Int           @id @default(autoincrement())
  name     String
  slug     String        @unique
  noteType NoteType
  perfumes PerfumeNote[]
}

model PerfumeNote {
  id        Int     @id @default(autoincrement())
  perfumeId Int
  noteId    Int
  intensity Int?
  perfume   Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  note      Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([perfumeId, noteId])
  @@index([noteId])
}

model Mood {
  id       Int           @id @default(autoincrement())
  name     String
  slug     String        @unique
  perfumes PerfumeMood[]
}

model PerfumeMood {
  id        Int     @id @default(autoincrement())
  perfumeId Int
  moodId    Int
  weight    Int?
  perfume   Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  mood      Mood    @relation(fields: [moodId], references: [id], onDelete: Cascade)

  @@unique([perfumeId, moodId])
  @@index([moodId])
}

model Season {
  id       Int             @id @default(autoincrement())
  name     String
  slug     String          @unique
  perfumes PerfumeSeason[]
}

model PerfumeSeason {
  id        Int     @id @default(autoincrement())
  perfumeId Int
  seasonId  Int
  weight    Int?
  perfume   Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  season    Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([perfumeId, seasonId])
  @@index([seasonId])
}

model Occasion {
  id       Int               @id @default(autoincrement())
  name     String
  slug     String            @unique
  perfumes PerfumeOccasion[]
}

model PerfumeOccasion {
  id         Int      @id @default(autoincrement())
  perfumeId  Int
  occasionId Int
  weight     Int?
  perfume    Perfume  @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  occasion   Occasion @relation(fields: [occasionId], references: [id], onDelete: Cascade)

  @@unique([perfumeId, occasionId])
  @@index([occasionId])
}

model PerfumeHomepagePlacement {
  id        Int             @id @default(autoincrement())
  perfumeId Int
  section   HomepageSection
  priority  Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  perfume   Perfume         @relation(fields: [perfumeId], references: [id], onDelete: Cascade)

  @@unique([perfumeId, section])
  @@index([section, priority])
  @@index([perfumeId])
}

model HomepageCollection {
  id                Int                    @id @default(autoincrement())
  title             String
  slug              String                 @unique
  subtitle          String?
  description       String?
  href              String
  type              HomepageCollectionType @default(FINDER_PRESET)
  isHomepageVisible Boolean                @default(false)
  homepagePriority  Int                    @default(0)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([isHomepageVisible, homepagePriority])
}

model Store {
  id               Int      @id @default(autoincrement())
  name             String
  slug             String   @unique
  websiteUrl       String
  affiliateProgram String?
  logoUrl          String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  offers           Offer[]
}

model Offer {
  id            Int          @id @default(autoincrement())
  perfumeId     Int
  storeId       Int
  productUrl    String
  affiliateUrl  String?
  priceAmount   Float
  currency      String
  shippingCost  Float?
  lastCheckedAt DateTime
  isBestPrice   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  perfume       Perfume      @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  store         Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([perfumeId])
  @@index([storeId])
  @@index([isBestPrice])
}

model AffiliateClick {
  id          Int      @id @default(autoincrement())
  perfumeSlug String?
  destination String
  targetUrl   String
  locale      String?
  createdAt   DateTime @default(now())

  @@index([perfumeSlug])
  @@index([destination])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id              Int                        @id @default(autoincrement())
  email           String                     @unique
  locale          String?
  status          NewsletterSubscriberStatus @default(SUBSCRIBED)
  source          String
  consentVersion  String
  consentText     String
  consentedAt     DateTime                   @default(now())
  unsubscribedAt  DateTime?
  lastSubmittedAt DateTime                   @default(now())
  ipHash          String?
  userAgent       String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@index([status])
  @@index([locale])
  @@index([consentedAt])
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id             Int            @id @default(autoincrement())
  slug           String
  locale         String
  status         BlogPostStatus @default(PUBLISHED)
  title          String
  excerpt        String
  tldr           String[]       @default([])
  content        String
  coverImageUrl  String?
  seoTitle       String?
  seoDescription String?
  tags           String[]
  publishedAt    DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([slug, locale])
  @@index([locale, status, publishedAt])
}
